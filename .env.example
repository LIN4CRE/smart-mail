# Gemini AI API key (server-side)
GEMINI_API_KEY="your_gemini_api_key"

# Firebase config (client-side, for Vite build)
# Create a Firebase project at https://console.firebase.google.com
# then enable Google Sign-In and set these:
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Vercel deployment URL (used by Capacitor APK for API calls)
# Set this during Vercel builds only
VITE_API_URL=""
